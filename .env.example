CHROMA_COLLECTION_NAME=products

# Sync Configuration
SYNC_CRON_HOUR=5
SYNC_CRON_MINUTE=0
SCHEDULER_ENABLED=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
