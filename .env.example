# Odoo 19 Configuration
ODOO_URL=https://your-odoo-instance.com
ODOO_API_KEY=your-odoo-api-key
ODOO_DB=your-database-name

# Google AI Configuration
GOOGLE_API_KEY=your-google-api-key

# ChromaDB Configuration
